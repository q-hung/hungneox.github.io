---
import BaseLayout from "./BaseLayout.astro";
import { homepageSectionIdFromCategories } from "../lib/home";

const { frontmatter } = Astro.props;
const d = new Date(frontmatter.date);
const isDateValid = !isNaN(d.getTime());

const site = Astro.site ?? new URL("https://butchiso.com");
const currentLang = Astro.currentLocale ?? "en";
const alt = frontmatter.alternate;

let alternateLocales: { lang: string; href: string }[] | undefined;
const altPath = alt ? `/${alt.lang}/blog/${alt.slug}/` : "";
if (alt) {
  const currentHref = new URL(Astro.url.pathname, site).href;
  const altHref = new URL(altPath, site).href;
  const viHref = currentLang === "vi" ? currentHref : altHref;
  const enHref = currentLang === "en" ? currentHref : altHref;
  alternateLocales = [
    { lang: "vi", href: viHref },
    { lang: "en", href: enHref },
  ];
}

const rawTags = frontmatter.tags;
const tagList: string[] = Array.isArray(rawTags)
  ? rawTags.map(String)
  : rawTags != null && rawTags !== ""
    ? [String(rawTags)]
    : [];

const ribbonLabel = Astro.currentLocale === "en" ? "Article" : "Bài viết";
const tocHeading =
  Astro.currentLocale === "en" ? "Table of Contents" : "Mục lục";

const postSectionId = homepageSectionIdFromCategories(frontmatter.categories);
const postRibbonSectionClass = postSectionId
  ? `post-ribbon--${postSectionId}`
  : undefined;
---

<BaseLayout
  title={frontmatter.title}
  description={frontmatter.description}
  image={frontmatter.image}
  tags={frontmatter.tags}
  alternateLocales={alternateLocales}
  langSwitcherHref={alt ? altPath : undefined}
>
  <div class="post-layout">
    <div class="post-card">
      <div class="post-card__window">
        <div class="post">
          <header class="post-header">
            <div
              class:list={["post-header__ribbon", postRibbonSectionClass]}
            >
              <span
                class="material-symbols-rounded post-header__ribbon-icon"
                aria-hidden="true">article</span
              >
              <span class="post-header__ribbon-text">{ribbonLabel}</span>
            </div>
            <div class="post-header__body">
              <h1 class="post-title" itemprop="name headline">
                {frontmatter.title}
              </h1>
              {
                tagList.length > 0 && (
                  <div
                    class="post-tags"
                    role="list"
                    aria-label={
                      Astro.currentLocale === "en" ? "Tags" : "Thẻ chủ đề"
                    }
                  >
                    {tagList.map((tag) => (
                      <span class="post-tag" role="listitem">
                        #{tag}
                      </span>
                    ))}
                  </div>
                )
              }
              <p class="post-meta">
                {
                  isDateValid && (
                    <time datetime={d.toISOString()} itemprop="datePublished">
                      {d.toLocaleDateString(
                        Astro.currentLocale === "en" ? "en-US" : "vi-VN",
                        { year: "numeric", month: "long", day: "numeric" },
                      )}
                    </time>
                  )
                }
                {
                  frontmatter.author && (
                    <span
                      itemprop="author"
                      itemscope
                      itemtype="http://schema.org/Person"
                    >
                      <span itemprop="name"> • {frontmatter.author}</span>
                    </span>
                  )
                }
              </p>
              {
                alt && (
                  <p class="post-translation">
                    <a
                      href={altPath}
                      hreflang={alt.lang}
                      lang={alt.lang}
                      class="post-translation-link"
                    >
                      {alt.lang === "en" ? "English version" : "Bản tiếng Việt"}
                    </a>
                  </p>
                )
              }
            </div>
          </header>
          <article
            class="post-content"
            id="post-content"
            itemprop="articleBody"
          >
            <slot />
          </article>
        </div>
      </div>
    </div>

    <aside class="toc-sidebar" id="toc-sidebar">
      <div class:list={["toc-sidebar__ribbon", postRibbonSectionClass]}>
        <span
          class="material-symbols-rounded toc-sidebar__ribbon-icon"
          aria-hidden="true">list</span
        >
        <h4 class="toc-sidebar__ribbon-title" id="toc-sidebar-heading">
          {tocHeading}
        </h4>
      </div>
      <div class="toc-sidebar__body">
        <nav class="toc" id="toc" aria-labelledby="toc-sidebar-heading">
          <ul class="toc-list" id="toc-list"></ul>
        </nav>
        <button
          type="button"
          class="toc-back-top"
          id="back-to-top"
          aria-label={Astro.currentLocale === "en"
            ? "Back to top"
            : "Về đầu trang"}
        >
          <span class="material-symbols-rounded">arrow_upward</span>
          {Astro.currentLocale === "en" ? "Back to top" : "Về đầu trang"}
        </button>
        <div class="toc-author">
          <img
            class="toc-avatar"
            src="//avatars.githubusercontent.com/u/199614?v=4"
            alt="Q-Hung"
          />
          <div class="toc-author-info">
            <span class="toc-author-name">Q-Hung</span>
            <span class="toc-author-desc">Software Engineer | Coffee lover</span
            >
            <div class="toc-author-links">
              <a href="https://linkedin.com/in/hungnq1989" title="LinkedIn"
                >LinkedIn</a
              >
              <a href="https://github.com/q-hung" title="GitHub">GitHub</a>
            </div>
          </div>
        </div>
      </div>
    </aside>
  </div>

  <script is:inline>
    (function () {
      var content = document.getElementById("post-content");
      var tocList = document.getElementById("toc-list");
      var tocSidebar = document.getElementById("toc-sidebar");
      if (!content || !tocList) return;

      var headings = content.querySelectorAll("h1, h2, h3");
      if (headings.length < 2) {
        if (tocSidebar) tocSidebar.style.display = "none";
        var pl = document.querySelector(".post-layout");
        if (pl) pl.classList.add("no-toc");
        return;
      }

      var minLevel = 6;
      headings.forEach(function (h) {
        var level = parseInt(h.tagName[1]);
        if (level < minLevel) minLevel = level;
      });

      headings.forEach(function (heading, i) {
        if (!heading.id) {
          heading.id = "heading-" + i;
        }

        var level = parseInt(heading.tagName[1]) - minLevel;
        var li = document.createElement("li");
        li.className = "toc-item toc-level-" + level;
        li.setAttribute("data-target", heading.id);

        var a = document.createElement("a");
        a.href = "#" + heading.id;
        a.textContent = heading.textContent;
        a.addEventListener("click", function (e) {
          e.preventDefault();
          heading.scrollIntoView({ behavior: "smooth", block: "start" });
          history.replaceState(null, "", "#" + heading.id);
        });

        li.appendChild(a);
        tocList.appendChild(li);
      });

      var tocItems = tocList.querySelectorAll(".toc-item");
      var observer = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              tocItems.forEach(function (item) {
                item.classList.remove("active");
              });
              var active = tocList.querySelector(
                '[data-target="' + entry.target.id + '"]',
              );
              if (active) active.classList.add("active");
            }
          });
        },
        { rootMargin: "0px 0px -70% 0px", threshold: 0 },
      );

      headings.forEach(function (h) {
        observer.observe(h);
      });

      var backBtn = document.getElementById("back-to-top");
      if (backBtn) {
        backBtn.addEventListener("click", function () {
          window.scrollTo({ top: 0, behavior: "smooth" });
        });
      }
    })();
  </script>
</BaseLayout>
