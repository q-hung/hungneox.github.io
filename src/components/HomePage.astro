---
import type { CategorizedHomePageProps } from "../lib/home";
import { estimateReadingTime } from "../lib/home";
import CategoryCard from "./CategoryCard.astro";

export interface Props {
  lang: "vi" | "en";
  home: CategorizedHomePageProps;
}

const { lang, home } = Astro.props;
const { featured, recentPosts, sections } = home;

function getPostHref(postId: string): string {
  const slug = postId.split("/").pop();
  return `/${lang}/blog/${slug}/`;
}

function truncateDescription(str: string | undefined, max: number): string {
  if (!str) return "";
  const t = str.trim();
  return t.length > max ? t.substring(0, max) + "…" : t;
}

const readMoreLabel = lang === "en" ? "Read More" : "Đọc tiếp";
const featuredLabel = lang === "en" ? "Featured Article" : "Bài viết nổi bật";
const recentLabel = lang === "en" ? "Recent posts" : "Bài viết gần đây";
const minReadLabel = lang === "en" ? "min read" : "phút đọc";
---

<div class="home home--categorized">
  <!-- ═══ Featured Article Hero ═══ -->
  {featured && (
    <section class="featured-hero" id="featured-hero">
      <div class="featured-hero__label">
        <span class="material-symbols-rounded">auto_awesome</span>
        {featuredLabel}
      </div>
      <a class="featured-hero__card" href={getPostHref(featured.id)}>
        <div class="featured-hero__image">
          {featured.data.image ? (
            <img src={featured.data.image} alt={featured.data.title} loading="eager" />
          ) : (
            <img src="/assets/images/abstract-0.jpg" alt={featured.data.title} loading="eager" />
          )}
          <div class="featured-hero__overlay"></div>
        </div>
        <div class="featured-hero__content">
          <h1 class="featured-hero__title">{featured.data.title}</h1>
          {featured.data.description && (
            <p class="featured-hero__desc">{featured.data.description}</p>
          )}
          <div class="featured-hero__meta">
            <span class="featured-hero__read-time">
              <span class="material-symbols-rounded">schedule</span>
              {estimateReadingTime(featured.body)} {minReadLabel}
            </span>
            <span class="featured-hero__cta">
              {readMoreLabel}
              <span aria-hidden="true">→</span>
            </span>
          </div>
        </div>
      </a>
    </section>
  )}

  {recentPosts.length > 0 && (
    <section class="recent-posts" id="recent-posts" aria-labelledby="recent-posts-heading">
      <h2 class="recent-posts__heading" id="recent-posts-heading">{recentLabel}</h2>
      <div class="recent-posts__grid">
        {recentPosts.map((post) => (
          <a class="recent-posts__card" href={getPostHref(post.id)}>
            <div class="recent-posts__thumb">
              <img
                src={post.data.image || "/assets/images/abstract-0.jpg"}
                alt={post.data.title}
                loading="lazy"
              />
            </div>
            <div class="recent-posts__body">
              <h3 class="recent-posts__title">{post.data.title}</h3>
              {post.data.description?.trim() && (
                <p class="recent-posts__desc">{truncateDescription(post.data.description, 140)}</p>
              )}
              <span class="recent-posts__meta">
                <span class="material-symbols-rounded" aria-hidden="true">schedule</span>
                {estimateReadingTime(post.body)} {minReadLabel}
              </span>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- ═══ Category Grid ═══ -->
  <section class="category-grid" id="category-grid">
    {sections.map((sec) => (
      <CategoryCard
        lang={lang}
        id={sec.id}
        label={sec.label}
        icon={sec.icon}
        viewAllHref={sec.viewAllHref}
        latest={sec.latest}
        older={sec.older}
        totalCount={sec.totalCount}
      />
    ))}
  </section>
</div>
