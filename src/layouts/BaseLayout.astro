---
import HeadSetup from '../components/HeadSetup.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/main.scss';

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  tags?: string[];
  /** Canonical pathname (e.g. `/`) when this URL duplicates another */
  url?: string;
}
const { title, description, image, tags, url } = Astro.props;
const lang = Astro.currentLocale || 'en';
---
<!DOCTYPE html>
<html lang={lang}>
  <head>
    <HeadSetup title={title} description={description} image={image} tags={tags} url={url} />
  </head>
  <body>
    <Header />
    <div class="page-content">
      <div class="wrapper">
        <slot />
      </div>
    </div>
    <Footer />
  </body>
</html>
