---
import type { CategorizedHomePageProps } from "../lib/home";
import { estimateReadingTime, getPostHubBadge } from "../lib/home";
import CategoryCard from "./CategoryCard.astro";

export interface Props {
  lang: "vi" | "en";
  home: CategorizedHomePageProps;
}

const { lang, home } = Astro.props;
const { featuredHubPosts: hubPosts, sections } = home;

function getPostHref(postId: string): string {
  const slug = postId.split("/").pop();
  return `/${lang}/blog/${slug}/`;
}

function truncateDescription(str: string | undefined, max: number): string {
  if (!str) return "";
  const t = str.trim();
  return t.length > max ? t.substring(0, max) + "…" : t;
}

const readMoreLabel = lang === "en" ? "Read More" : "Đọc tiếp";
const hubRibbonLabel = lang === "en" ? "Featured content" : "Nội dung nổi bật";
const hubSideLabel =
  lang === "en" ? "Other recent posts" : "Bài viết gần đây khác";
const minReadLabel = lang === "en" ? "min read" : "phút đọc";

const hubSolo = hubPosts.length <= 1;
---

<div class="home home--categorized">
  {hubPosts.length > 0 && (
    <section
      class:list={["featured-hub", hubSolo && "featured-hub--solo"]}
      id="featured-content-hub"
      data-active="0"
      aria-label={hubRibbonLabel}
    >
      <div class="featured-hub__ribbon">
        <span class="featured-hub__ribbon-text">{hubRibbonLabel}</span>
      </div>
      <div class="featured-hub__frame">
        <div class="featured-hub__main">
          {hubPosts.map((post, i) => (
            <a
              class="featured-hub__main-card"
              id={`hub-main-${i}`}
              data-hub-index={i}
              href={getPostHref(post.id)}
              aria-hidden={i === 0 ? "false" : "true"}
              tabindex={i === 0 ? 0 : -1}
            >
              <div class="featured-hub__main-media">
                <img
                  src={post.data.image || "/assets/images/abstract-0.jpg"}
                  alt={post.data.title}
                  loading={i === 0 ? "eager" : "lazy"}
                  decoding="async"
                />
                <div class="featured-hub__main-overlay"></div>
              </div>
              <div class="featured-hub__main-content">
                <p class="featured-hub__main-kicker">
                  {i + 1}. {lang === "en" ? "Main feature" : "Bài chính"}
                </p>
                <h2 class="featured-hub__main-title">{post.data.title}</h2>
                {post.data.description?.trim() && (
                  <p class="featured-hub__main-desc">
                    {truncateDescription(post.data.description, 220)}
                  </p>
                )}
                <div class="featured-hub__main-meta">
                  <span class="featured-hub__main-read">
                    <span class="material-symbols-rounded" aria-hidden="true">schedule</span>
                    {estimateReadingTime(post.body)} {minReadLabel}
                  </span>
                  <span class="featured-hub__main-cta">
                    {readMoreLabel}
                    <span aria-hidden="true">→</span>
                  </span>
                </div>
              </div>
            </a>
          ))}
        </div>

        {!hubSolo && (
          <aside class="featured-hub__side" aria-label={hubSideLabel}>
            <div class="featured-hub__side-list">
              {hubPosts.map((post, i) => (
                <button
                  type="button"
                  class="featured-hub__pick"
                  id={`hub-tab-${i}`}
                  data-hub-index={i}
                  aria-pressed={i === 0 ? "true" : "false"}
                  aria-controls={`hub-main-${i}`}
                >
                  <span class="featured-hub__pick-index" aria-hidden="true">{i + 1}</span>
                  <span class="featured-hub__pick-body">
                    <span class="featured-hub__pick-badge">
                      [{getPostHubBadge(post, lang)}]
                    </span>
                    <span class="featured-hub__pick-title">{post.data.title}</span>
                  </span>
                </button>
              ))}
            </div>
          </aside>
        )}
      </div>
    </section>
  )}

  <!-- ═══ Category Grid ═══ -->
  <section class="category-grid" id="category-grid">
    {sections.map((sec) => (
      <CategoryCard
        lang={lang}
        id={sec.id}
        label={sec.label}
        icon={sec.icon}
        viewAllHref={sec.viewAllHref}
        latest={sec.latest}
        older={sec.older}
        totalCount={sec.totalCount}
      />
    ))}
  </section>
</div>

{hubPosts.length > 1 && (
  <script is:inline>
    (function () {
      var root = document.getElementById("featured-content-hub");
      if (!root) return;

      function setActive(i) {
        var idx = String(i);
        root.setAttribute("data-active", idx);

        root.querySelectorAll(".featured-hub__pick").forEach(function (btn) {
          var bi = btn.getAttribute("data-hub-index");
          var on = bi === idx;
          btn.setAttribute("aria-pressed", on ? "true" : "false");
        });

        root.querySelectorAll(".featured-hub__main-card").forEach(function (panel) {
          var pi = panel.getAttribute("data-hub-index");
          var on = pi === idx;
          panel.setAttribute("aria-hidden", on ? "false" : "true");
          panel.setAttribute("tabindex", on ? "0" : "-1");
        });
      }

      root.querySelectorAll(".featured-hub__pick").forEach(function (btn) {
        btn.addEventListener("click", function () {
          var i = btn.getAttribute("data-hub-index");
          if (i != null) setActive(i);
        });
      });
    })();
  </script>
)}
