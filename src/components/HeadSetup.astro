---
export interface Props {
  title?: string;
  description?: string;
  image?: string;
  tags?: string[];
  url?: string;
  /** Same page in other locales for `<link rel="alternate" hreflang="…">` */
  alternateLocales?: { lang: string; href: string }[];
}

const { title, description, image, tags, url, alternateLocales } = Astro.props;
const siteTitle = "Q-Hung";
const siteDescription = "Software Engineer | Coffee lover";

const finalTitle = title ? `${title} - ${siteTitle}` : siteTitle;
const finalDesc = description || siteDescription;
const finalImage = new URL(
  image || "/assets/images/butchiso.jpg",
  Astro.site || "https://butchiso.com",
);
const canonicalUrl = new URL(
  url || Astro.url.pathname,
  Astro.site || "https://butchiso.com",
);
---

<meta charset="utf-8" />
<meta http-equiv="X-UA-Compatible" content="IE=edge" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<!-- Favicon early: browsers cache aggressively; SVG needs sizes="any" for broad support -->
<link
  rel="icon"
  href={`${import.meta.env.BASE_URL}favicon.svg`}
  type="image/svg+xml"
  sizes="any"
/>

<title>{finalTitle}</title>
<meta name="description" content={finalDesc} />

{tags && tags.length > 0 && <meta name="keywords" content={tags.join(", ")} />}

<!-- Open Graph -->
<meta property="og:locale" content="vi_VN" />
<meta property="og:type" content="article" />
<meta property="og:title" content={finalTitle} />
<meta property="og:description" content={finalDesc} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:site_name" content={siteTitle} />
<meta property="og:image" content={finalImage} />

<link rel="canonical" href={canonicalUrl} />
{
  alternateLocales?.map(({ lang, href }) => (
    <link rel="alternate" hreflang={lang} href={href} />
  ))
}
<link
  href="/feed.xml"
  type="application/atom+xml"
  rel="alternate"
  title={`${siteTitle} Feed`}
/>

<meta name="HandheldFriendly" content="True" />
<meta name="MobileOptimized" content="320" />

<!-- Webfonts -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Google+Sans:wght@400;500;700&family=Google+Sans+Mono:wght@400;500&display=swap"
  rel="stylesheet"
/>
<link
  href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&icon_names=arrow_upward,article,auto_awesome,category,close,code,dark_mode,dns,home,language,light_mode,list,mail,menu,rss_feed,schedule,science,search&display=block"
  rel="stylesheet"
/>

<script is:inline type="text/x-mathjax-config">
  MathJax.Hub.Config({
    displayAlign: "center",
    displayIndent: "0",
    tex2jax: {
      inlineMath: [
        ["\\(", "\\)"],
        ["$", "$"],
      ],
      displayMath: [
        ["$$", "$$"],
        ["\\[", "\\]"],
      ],
      processEscapes: true,
      skipTags: ["script", "noscript", "style", "textarea", "pre", "code"],
    },
  });
</script>
<script
  type="text/javascript"
  src="https://cdn.mathjax.org/mathjax/latest/MathJax.js?config=TeX-AMS-MML_HTMLorMML"
></script>

<script is:inline>
  (function () {
    var t = localStorage.getItem("theme");
    if (
      t === "dark" ||
      (!t && window.matchMedia("(prefers-color-scheme:dark)").matches)
    ) {
      document.documentElement.setAttribute("data-theme", "dark");
    }
  })();
</script>
