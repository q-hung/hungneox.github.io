---
import HeadSetup from "../components/HeadSetup.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/main.scss";

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  tags?: string[];
  /** Canonical pathname (e.g. `/`) when this URL duplicates another */
  url?: string;
  alternateLocales?: { lang: string; href: string }[];
  /** Overrides header language switcher (e.g. blog post with different slug per locale) */
  langSwitcherHref?: string;
}
const {
  title,
  description,
  image,
  tags,
  url,
  alternateLocales,
  langSwitcherHref,
} = Astro.props;
const lang = Astro.currentLocale || "en";
---

<!doctype html>
<html lang={lang}>
  <head>
    <HeadSetup
      title={title}
      description={description}
      image={image}
      tags={tags}
      url={url}
      alternateLocales={alternateLocales}
    />
  </head>
  <body>
    <Header langSwitcherHref={langSwitcherHref} />
    <div class="page-content">
      <div class="wrapper">
        <slot />
      </div>
    </div>
    <Footer lang={lang} />
  </body>
</html>
