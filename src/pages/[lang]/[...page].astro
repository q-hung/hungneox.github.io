---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import HomePage from '../../components/HomePage.astro';
import { getCategorizedHomePage } from '../../lib/home';

export async function getStaticPaths({ paginate }: any) {
  const allPosts = await getCollection('blog', ({ data }) => data.published !== false);
  
  const viPosts = allPosts.filter(({ id }) => id.startsWith('vi/'));
  const enPosts = allPosts.filter(({ id }) => id.startsWith('en/'));

  viPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
  enPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

  const viPaginated = paginate(viPosts, { params: { lang: 'vi' }, pageSize: 10 });
  const viFromPage2 = viPaginated.filter(
    (entry: { props: { page: { currentPage: number } } }) =>
      entry.props.page.currentPage > 1,
  );

  const enPaginated = paginate(enPosts, { params: { lang: 'en' }, pageSize: 10 });
  const enFromPage2 = enPaginated.filter(
    (entry: { props: { page: { currentPage: number } } }) =>
      entry.props.page.currentPage > 1,
  );

  return [...viFromPage2, ...enFromPage2];
}

const { lang } = Astro.params;
const title = lang === 'en' ? 'Home' : 'Trang chủ';
const home = await getCategorizedHomePage(lang as 'vi' | 'en');
---
<BaseLayout title={title}>
  <HomePage lang={lang as 'vi' | 'en'} home={home} />
</BaseLayout>
